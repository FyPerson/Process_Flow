# 依赖
node_modules/
# package-lock.json: 故意跟踪到仓库，保证多端依赖版本一致（含 better-sqlite3 native 版本）

# 构建输出
dist/
build/
*.local
*.tsbuildinfo

# 环境变量
.env
.env.local
.env.*.local

# 日志
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# 编辑器
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# Claude Code 运行时文件（per-machine 状态，不该入仓库）
# - settings.local.json：Claude Code 自动维护的工具权限白名单
# - scheduled_tasks.lock：当前 session 的定时任务锁（含 pid，会话间不可移植）
# 注意：.claude/skills/ 是项目共享的 skill 定义，要入仓库
.claude/settings.local.json
.claude/scheduled_tasks.lock

# 操作系统
.DS_Store
Thumbs.db
Desktop.ini

# 备份文件
backup_*/
*.zip
*.tar.gz

# 临时文件
*.tmp
*.temp
.cache/

# 测试覆盖率
coverage/
.nyc_output/

# 本地开发记录（不推送到服务器）
开发记录.md
PLAN-*.md
TODO.md
项目潜在风险清单.md
docs/历史/

# 本地素材与数据档案见 E:\业务全景图_assets\

# 部署钩子本地副本（根目录的本地拷贝；scripts/server-hooks/ 是入仓库的模板）
/server-hooks/

# 一次性分析输出
eslint-*.json
eslint-*.txt
lint-report.*
tsc_errors.log

# 合同/法务文档不应进入代码仓库
*.docx

