{
  "name": "business-flow-react",
  "version": "1.3.0",
  "description": "业务流程全景图 - React Flow 实现",
  "type": "module",
  "scripts": {
    "dev": "concurrently -n api,vite -c blue,green --kill-others-on-fail \"npm:dev:api\" \"npm:dev:vite\"",
    "dev:api": "tsx watch server/index.ts",
    "dev:vite": "vite",
    "build": "tsc -b tsconfig.json && vite build",
    "start": "cross-env NODE_ENV=production tsx server/index.ts",
    "preview": "vite preview",
    "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write .",
    "test": "node --import tsx --test \"src/**/*.test.ts\" \"server/**/*.test.ts\""
  },
  "dependencies": {
    "@types/dagre": "^0.7.53",
    "@xyflow/react": "^12.4.4",
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^12.9.0",
    "dagre": "^0.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.0.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "nanoid": "^5.0.9",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.9.6",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bcrypt": "^5.0.2",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^24.10.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "pino-pretty": "^11.3.0",
    "prettier": "^3.7.4",
    "tsx": "^4.19.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.48.1",
    "vite": "^6.3.5"
  }
}
